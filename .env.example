# Copy to .env and fill in to run locally:  `node --env-file=.env update-playlist.mjs`
# (Do NOT commit .env — it's gitignored.)

# Spotify app credentials — https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Your Spotify username/user ID. Find it: Spotify → your profile → "..." →
# Share → Copy link to profile. The ID is the part after /user/ in the URL.
SPOTIFY_USER_ID=

# Your omg.lol address (the part before .omg.lol). For samd.omg.lol this is "samd".
OMGLOL_ADDRESS=samd

# omg.lol API key — https://home.omg.lol/account (Account → API key)
OMGLOL_API_KEY=

# Timezone used to compute the month name (e.g. "June 2026"). Optional; UTC default.
PLAYLIST_TZ=America/Chicago
